<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solar System of Love 🪐</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Orbitron:wght@400;700&display=swap');

  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: #020010;
    overflow: hidden;
    width: 100vw;
    height: 100vh;
  }

  nav {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    display: flex;
    gap: 20px;
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,200,255,0.2);
    border-radius: 50px;
    padding: 8px 24px;
  }
  nav a {
    color: #f0c8f8;
    text-decoration: none;
    font-size: 15px;
    font-family: 'Dancing Script', cursive;
    transition: color 0.3s;
  }
  nav a:hover { color: #fff; }
  nav a.active { color: #ff9ee8; font-weight: 700; }

  canvas { display: block; }

  #message {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Dancing Script', cursive;
    font-size: 52px;
    color: transparent;
    text-shadow: 0 0 30px rgba(255,100,220,0.8);
    letter-spacing: 8px;
    pointer-events: none;
    z-index: 100;
    opacity: 0;
    transition: opacity 2s;
    -webkit-text-stroke: 1px rgba(255,150,240,0.9);
  }

  #hint {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(200,150,240,0.6);
    font-family: 'Dancing Script', cursive;
    font-size: 16px;
    animation: fadeHint 2s ease-in-out infinite;
  }
  @keyframes fadeHint {
    0%,100%{opacity:0.4} 50%{opacity:0.9}
  }
</style>
</head>
<body>

<nav>
  <a href="page1.html">🌷 Bouquet</a>
  <a href="page2.html" class="active">🪐 Solar System</a>
  <a href="page3.html">⛰️ Mountain</a>
</nav>

<canvas id="c"></canvas>
<div id="message">i love you</div>
<div id="hint">watch the planets align...</div>

<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

const cx = canvas.width/2, cy = canvas.height/2;

// ---- STARS ----
const stars = Array.from({length:300}, () => ({
  x: Math.random()*canvas.width,
  y: Math.random()*canvas.height,
  r: Math.random()*1.5+0.2,
  alpha: Math.random()*0.6+0.4,
  phase: Math.random()*Math.PI*2,
  speed: Math.random()*0.02+0.005
}));

// ---- SENTENCE ----
// "i love you" -> 9 chars including spaces, assign to planets
// We'll split: ['i',' ','l','o','v','e',' ','y','o','u'] - use 8 planets + sun as anchor
// Planets (8): Mercury, Venus, Earth, Mars, Jupiter, Saturn, Uranus, Neptune
// Letters: i l o v e y o u  (skip spaces for planets, show spaces in message)

const SENTENCE = "i love you";
const LETTERS = ['i','l','o','v','e','y','o','u'];

const SUN_R = 38;

const planets = [
  { name:'Mercury', letter:'i', orbit:90,  r:7,   period:6,   colors:['#b5a0c0','#a090b0','#c0b0d0'], ringless:true },
  { name:'Venus',   letter:'l', orbit:140, r:12,  period:10,  colors:['#f0c890','#e0a860','#ffd8a0'], ringless:true },
  { name:'Earth',   letter:'o', orbit:195, r:13,  period:15,  colors:['#5090d0','#60c070','#3070b0'], ringless:true },
  { name:'Mars',    letter:'v', orbit:248, r:10,  period:22,  colors:['#d06030','#c04020','#e08060'], ringless:true },
  { name:'Jupiter', letter:'e', orbit:315, r:22,  period:38,  colors:['#e0c0a0','#c09070','#b08060'], ringless:true },
  { name:'Saturn',  letter:'y', orbit:385, r:18,  period:58,  colors:['#d4b896','#c8a880','#e0c8a8'], ring:true },
  { name:'Uranus',  letter:'o', orbit:440, r:14,  period:80,  colors:['#88d0e0','#70bcd0','#a0e0f0'], ringless:true },
  { name:'Neptune', letter:'u', orbit:490, r:13,  period:110, colors:['#4060d0','#3050c0','#6080e0'], ringless:true },
];

// Each planet has an angle offset
planets.forEach((p,i) => {
  p.angle = (i/planets.length) * Math.PI*2 + Math.PI*0.3;
  p.baseAngle = p.angle;
});

// ---- ALIGNMENT DETECTION ----
// We detect when planets roughly spell out "i love you"
// We'll create a timed sequence: every 12s, trigger alignment
let alignPhase = 0; // 0=orbiting, 1=aligning, 2=showing word, 3=dispersing
let alignTimer = 0;
const ALIGN_INTERVAL = 18000;
const ALIGN_DURATION = 4000;
const WORD_DURATION = 5000;
let lastTime = performance.now();
let totalTime = 0;
let messageEl = document.getElementById('message');
let showingWord = false;

// Target positions for "i love you" word display
function getWordTargets() {
  const wordW = LETTERS.length * 55;
  const startX = cx - wordW/2;
  return LETTERS.map((l,i) => ({
    x: startX + i*55 + 27,
    y: cy
  }));
}

function drawSun(t) {
  // Corona rays
  for (let i=0; i<16; i++) {
    const a = (i/16)*Math.PI*2 + t*0.0005;
    const len = SUN_R + Math.sin(t*0.003+i)*8 + 12;
    const grd = ctx.createLinearGradient(cx,cy, cx+Math.cos(a)*len, cy+Math.sin(a)*len);
    grd.addColorStop(0,'rgba(255,200,100,0.5)');
    grd.addColorStop(1,'rgba(255,200,100,0)');
    ctx.strokeStyle = grd;
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(cx+Math.cos(a)*SUN_R*0.8, cy+Math.sin(a)*SUN_R*0.8);
    ctx.lineTo(cx+Math.cos(a)*len, cy+Math.sin(a)*len);
    ctx.stroke();
  }

  // Outer glow
  const glow = ctx.createRadialGradient(cx,cy,0,cx,cy,SUN_R*2.5);
  glow.addColorStop(0,'rgba(255,200,80,0.3)');
  glow.addColorStop(0.4,'rgba(255,150,50,0.15)');
  glow.addColorStop(1,'rgba(255,100,0,0)');
  ctx.fillStyle = glow;
  ctx.beginPath(); ctx.arc(cx,cy,SUN_R*2.5,0,Math.PI*2); ctx.fill();

  // Sun body
  const sunG = ctx.createRadialGradient(cx-8,cy-8,0,cx,cy,SUN_R);
  sunG.addColorStop(0,'#fff8d0');
  sunG.addColorStop(0.3,'#ffe040');
  sunG.addColorStop(0.7,'#ff9900');
  sunG.addColorStop(1,'#dd5500');
  ctx.fillStyle = sunG;
  ctx.beginPath(); ctx.arc(cx,cy,SUN_R,0,Math.PI*2); ctx.fill();

  // Surface flares
  ctx.save();
  ctx.globalAlpha = 0.3;
  for (let f=0; f<5; f++) {
    const fa = t*0.001+f*1.2;
    const fr = SUN_R*0.6;
    const fs = 8+Math.sin(t*0.004+f)*4;
    ctx.fillStyle = '#ffee80';
    ctx.beginPath();
    ctx.arc(cx+Math.cos(fa)*fr, cy+Math.sin(fa)*fr, fs, 0, Math.PI*2);
    ctx.fill();
  }
  ctx.restore();
}

function drawOrbit(planet) {
  ctx.save();
  ctx.globalAlpha = 0.15;
  ctx.strokeStyle = '#cc88ff';
  ctx.lineWidth = 1;
  ctx.setLineDash([4,8]);
  ctx.beginPath();
  ctx.arc(cx, cy, planet.orbit, 0, Math.PI*2);
  ctx.stroke();
  ctx.setLineDash([]);
  ctx.restore();
}

function drawPlanet(planet, px, py, t, alpha=1) {
  ctx.save();
  ctx.globalAlpha = alpha;

  // Shadow
  ctx.fillStyle = 'rgba(0,0,0,0.4)';
  ctx.beginPath();
  ctx.arc(px+3, py+3, planet.r+1, 0, Math.PI*2);
  ctx.fill();

  // Planet glow
  const pGlow = ctx.createRadialGradient(px,py,0,px,py,planet.r*2.5);
  pGlow.addColorStop(0,planet.colors[0]+'44');
  pGlow.addColorStop(1,'transparent');
  ctx.fillStyle = pGlow;
  ctx.beginPath(); ctx.arc(px,py,planet.r*2.5,0,Math.PI*2); ctx.fill();

  // Planet body
  const pG = ctx.createRadialGradient(px-planet.r*0.3,py-planet.r*0.3,0,px,py,planet.r);
  pG.addColorStop(0,'#ffffff66');
  pG.addColorStop(0.2,planet.colors[0]);
  pG.addColorStop(0.7,planet.colors[1]);
  pG.addColorStop(1,planet.colors[2]);
  ctx.fillStyle = pG;
  ctx.shadowColor = planet.colors[0];
  ctx.shadowBlur = 12;
  ctx.beginPath(); ctx.arc(px,py,planet.r,0,Math.PI*2); ctx.fill();

  // Saturn ring
  if (planet.ring) {
    ctx.save();
    ctx.globalAlpha = alpha*0.8;
    ctx.strokeStyle = '#d4c898';
    ctx.lineWidth = planet.r*0.3;
    ctx.beginPath();
    ctx.ellipse(px, py, planet.r*1.9, planet.r*0.5, 0.2, 0, Math.PI*2);
    ctx.stroke();
    ctx.strokeStyle = '#c8b888';
    ctx.lineWidth = planet.r*0.15;
    ctx.beginPath();
    ctx.ellipse(px, py, planet.r*2.3, planet.r*0.65, 0.2, 0, Math.PI*2);
    ctx.stroke();
    ctx.restore();
  }

  // Earth clouds
  if (planet.name === 'Earth') {
    ctx.save();
    ctx.globalAlpha = alpha*0.4;
    ctx.fillStyle = '#ffffff';
    for (let c=0; c<4; c++) {
      const ca = t*0.001+c*1.6;
      ctx.beginPath();
      ctx.arc(px+Math.cos(ca)*planet.r*0.5, py+Math.sin(ca)*planet.r*0.5, planet.r*0.3, 0, Math.PI*2);
      ctx.fill();
    }
    ctx.restore();
  }

  // LETTER
  ctx.save();
  ctx.globalAlpha = alpha;
  ctx.fillStyle = '#fff';
  ctx.font = `bold ${Math.round(planet.r*1.1)}px 'Dancing Script'`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.shadowColor = '#ff88ff';
  ctx.shadowBlur = 8;
  ctx.fillText(planet.letter, px, py);
  ctx.restore();

  ctx.restore();
}

function lerp(a,b,t) { return a+(b-a)*t; }

let frame = 0;
function render(ts) {
  const dt = ts - lastTime;
  lastTime = ts;
  totalTime += dt;
  frame++;

  ctx.clearRect(0,0,canvas.width,canvas.height);

  // BG
  const bg = ctx.createRadialGradient(cx,cy,0,cx,cy,Math.max(canvas.width,canvas.height)*0.7);
  bg.addColorStop(0,'#08001a');
  bg.addColorStop(0.5,'#04000f');
  bg.addColorStop(1,'#020008');
  ctx.fillStyle = bg;
  ctx.fillRect(0,0,canvas.width,canvas.height);

  // Stars
  for (const s of stars) {
    const a = s.alpha + Math.sin(totalTime*s.speed+s.phase)*0.3;
    ctx.globalAlpha = Math.max(0.1, a);
    ctx.fillStyle = '#ffffff';
    ctx.beginPath();
    ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
    ctx.fill();
  }
  ctx.globalAlpha = 1;

  // Nebula swirl
  ctx.save();
  ctx.globalAlpha = 0.04;
  const neb = ctx.createRadialGradient(cx*0.6,cy*0.4,0,cx,cy,canvas.width*0.6);
  neb.addColorStop(0,'#cc44ff');
  neb.addColorStop(0.4,'#8800cc');
  neb.addColorStop(1,'transparent');
  ctx.fillStyle = neb;
  ctx.fillRect(0,0,canvas.width,canvas.height);
  ctx.restore();

  // Alignment cycle
  const cycle = totalTime % ALIGN_INTERVAL;
  const alignStart = ALIGN_INTERVAL - ALIGN_DURATION - WORD_DURATION;

  let wordTargets = getWordTargets();
  let inWordPhase = false;

  // Draw orbits
  for (const p of planets) drawOrbit(p);

  // Sun
  drawSun(totalTime);

  // Draw lines when forming word
  if (cycle > alignStart + ALIGN_DURATION * 0.5 && cycle < alignStart + ALIGN_DURATION + WORD_DURATION) {
    const wordProgress = Math.min(1,(cycle-(alignStart+ALIGN_DURATION*0.5))/(WORD_DURATION));
    if (wordProgress > 0.1) {
      ctx.save();
      ctx.globalAlpha = Math.min(0.8, wordProgress*2) * (cycle > ALIGN_INTERVAL - WORD_DURATION*0.2 ? Math.max(0,1-(cycle-(ALIGN_INTERVAL-WORD_DURATION*0.2))/(WORD_DURATION*0.2)) : 1);
      ctx.strokeStyle = 'rgba(255,150,240,0.5)';
      ctx.lineWidth = 1.5;
      ctx.setLineDash([6,10]);
      // Draw constellation lines connecting planets in order
      for (let i=0; i<planets.length-1; i++) {
        const p1 = planets[i], p2 = planets[i+1];
        ctx.beginPath();
        ctx.moveTo(p1._x, p1._y);
        ctx.lineTo(p2._x, p2._y);
        ctx.stroke();
      }
      ctx.setLineDash([]);
      ctx.restore();
    }
  }

  // Planets
  for (let i=0; i<planets.length; i++) {
    const p = planets[i];
    const tgt = wordTargets[i];

    let px, py;

    if (cycle > alignStart) {
      const alignProgress = Math.min(1,(cycle-alignStart)/ALIGN_DURATION);
      const eased = 1-Math.pow(1-alignProgress,3);
      const orbX = cx + Math.cos(p.angle) * p.orbit;
      const orbY = cy + Math.sin(p.angle) * p.orbit;

      if (cycle < alignStart + ALIGN_DURATION) {
        px = lerp(orbX, tgt.x, eased);
        py = lerp(orbY, tgt.y, eased);
        inWordPhase = false;
      } else if (cycle < alignStart + ALIGN_DURATION + WORD_DURATION) {
        px = tgt.x;
        py = tgt.y;
        inWordPhase = true;
      } else {
        const ret = Math.min(1,(cycle - (alignStart+ALIGN_DURATION+WORD_DURATION))/(ALIGN_DURATION));
        px = lerp(tgt.x, orbX, ret);
        py = lerp(tgt.y, orbY, ret);
        inWordPhase = false;
      }
    } else {
      p.angle = p.baseAngle + (totalTime/1000) * (Math.PI*2/p.period);
      px = cx + Math.cos(p.angle) * p.orbit;
      py = cy + Math.sin(p.angle) * p.orbit;
    }

    p._x = px; p._y = py;
    drawPlanet(p, px, py, totalTime);
  }

  // Message overlay
  if (inWordPhase) {
    if (!showingWord) {
      messageEl.style.opacity = '1';
      showingWord = true;
      document.getElementById('hint').style.opacity='0';
    }
  } else {
    if (showingWord) {
      messageEl.style.opacity = '0';
      showingWord = false;
      document.getElementById('hint').style.opacity='1';
    }
    // Update angle for next frame
    for (const p of planets) {
      p.angle = p.baseAngle + (totalTime/1000) * (Math.PI*2/p.period);
    }
  }

  requestAnimationFrame(render);
}
requestAnimationFrame(render);

window.addEventListener('resize', () => {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
});
</script>
</body>
</html>
